# --- Core ---
ELON_ENV=dev
ELON_LOG_LEVEL=INFO
ELON_BASE_URL=https://your-tunnel.trycloudflare.com

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=elon
POSTGRES_USER=elon
POSTGRES_PASSWORD=change_me

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO ---
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=elonminio
S3_SECRET_KEY=change_me_minio
S3_BUCKET=elon

# --- Auth / crypto ---
# 32 bytes, base64. Generate: python -c "import nacl.utils,base64;print(base64.b64encode(nacl.utils.random(32)).decode())"
SECRET_BOX_KEY=
JWT_SECRET=change_me_jwt
JWT_ALG=HS256
JWT_TTL_HOURS=72

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_PLANNER=claude-opus-4-7

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_me_tg_secret

# --- Meta (Instagram + Facebook + WhatsApp) ---
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT=/oauth/meta/callback
WHATSAPP_VERIFY_TOKEN=change_me_wa_verify

# --- TikTok ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_OAUTH_REDIRECT=/oauth/tiktok/callback

# --- Search ---
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Budget defaults ---
TENANT_MONTHLY_BUDGET_USD=50
BUDGET_ALERT_THRESHOLDS=0.8,1.0
